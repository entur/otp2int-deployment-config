<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<TargetEndpoint name="journey-planner-v3-international">
  <DefaultFaultRule name="DefaultFaultRule">
    <Step>
      <FaultRules/>
      <Name>flowCallout.generalSecurityHeaders</Name>
    </Step>
    <Step>
      <FaultRules/>
      <Name>assignMessage.addCors</Name>
    </Step>
    <AlwaysEnforce>false</AlwaysEnforce>
  </DefaultFaultRule>
  <Description/>
  <FaultRules/>
  <Flows/>
  <PostFlow name="PostFlow">
    <Request/>
    <Response>
      <Step>
        <FaultRules/>
        <Name>flowCallout.generalSecurityHeaders</Name>
      </Step>
    </Response>
  </PostFlow>
  <PreFlow name="PreFlow">
    <Request>
      <Step>
        <FaultRules/>
        <Name>flowCallout.replaceTargetUrl</Name>
      </Step>
    </Request>
    <Response>
      <Step>
        <FaultRules/>
        <Name>assignMessage.addCors</Name>
      </Step>
    </Response>
  </PreFlow>
  <HTTPTargetConnection>
    <Properties/>
    <URL>https://otp2int.INGRESS_ENVIRONMENT/otp/routers/norway/transmodel/index</URL>
  </HTTPTargetConnection>
</TargetEndpoint>

<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<ProxyEndpoint name="journey-planner-v3-international">
  <Description/>
  <FaultRules>
    <FaultRule name="raiseFault-spikeArrestNoId">
      <Condition>ratelimit.spikeArrestNoId.failed = true</Condition>
      <Step>
        <FaultRules/>
        <Name>raiseFault.spikeArrestNoId</Name>
      </Step>
    </FaultRule>
  </FaultRules>
  <Flows/>
  <PostFlow name="PostFlow">
    <Request/>
    <Response/>
  </PostFlow>
  <PreFlow name="PreFlow">
    <Request>
      <Step>
        <FaultRules/>
        <Name>flowCallout.globalIpBlacklistTeamRutedata</Name>
      </Step>
      <Step>
        <Condition>request.header.Et-Client-Name is null</Condition>
        <FaultRules/>
        <Name>spikeArrestNoId</Name>
      </Step>
      <Step>
        <FaultRules/>
        <Name>spikeArrest</Name>
      </Step>
      <Step>
        <FaultRules/>
        <Name>flowCallout.getEnvironmentConfiguration</Name>
      </Step>
      <Step>
        <FaultRules/>
        <Name>flowCallout.journeyPlannerAddQueryTypeToHeader</Name>
      </Step>
    </Request>
    <Response/>
  </PreFlow>
  <HTTPProxyConnection>
    <BasePath>/journey-planner/v3/international</BasePath>
    <Properties/>
    <VirtualHost>entur</VirtualHost>
  </HTTPProxyConnection>
  <RouteRule name="journey-planner-v3-international">
    <TargetEndpoint>journey-planner-v3-international</TargetEndpoint>
  </RouteRule>
</ProxyEndpoint>
